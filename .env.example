# Discord Bot
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_application_client_id_here

# The owner/admin Discord user ID who receives the DM report embed
ADMIN_USER_ID=your_discord_user_id_here

# Render App URL (no trailing slash)
RENDER_URL=https://myapp.onrender.com

# Database
# For SQLite (local dev / Render with persistent disk):
DATABASE_URL="file:./dev.db"

# For PostgreSQL on Render (recommended for production):
# DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Server port (Render sets this automatically)
PORT=3000
